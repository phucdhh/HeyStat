# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://heystat:heystat@db:5432/classroom
SYNC_DATABASE_URL=postgresql+psycopg2://heystat:heystat@db:5432/classroom

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ─────────────────────────────────────────────────────────
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-random-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File storage ─────────────────────────────────────────────────
UPLOAD_DIR=/uploads
JAMOVI_DATA_ROOT=/root/Documents
MAX_FILE_SIZE_MB=50
MAX_USER_FILES=100
MAX_USER_STORAGE_MB=500

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Celery ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Email (optional – for password reset) ───────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
